@Composable
fun TelaLoja(navController: NavController) {
    Column(modifier = Modifier.padding(16.dp)) {

        Text("Loja de Roupas ", style = MaterialTheme.typography.titleLarge)

        Spacer(modifier = Modifier.height(16.dp))

        ProdutoCard(Produto("Camiseta", "R$50"), navController)
        ProdutoCard(Produto("Calça Jeans", "R$120"), navController)
        ProdutoCard(Produto("Jaqueta", "R$200"), navController)
    }
}

@Composable
fun TelaDetalhes(nome: String, preco: String, navController: NavController) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        horizontalAlignment = Alignment.CenterHorizontally
    ) {

        Image(
            painter = painterResource(id = R.drawable.patixaa),
            contentDescription = "Produto",
            modifier = Modifier.size(150.dp)
        )

        Spacer(modifier = Modifier.height(20.dp))

        Text(text = nome, style = MaterialTheme.typography.titleLarge)
        Text(text = preco, style = MaterialTheme.typography.titleMedium)

        Spacer(modifier = Modifier.height(20.dp))

        Button(onClick = {
            navController.popBackStack()
        }) {
            Text("Voltar")
        }
    }
}

@Composable
fun NavegacaoApp() {
    val navController = rememberNavController()

    NavHost(
        navController = navController,
        startDestination = "loja"
    ) {

        composable("loja") {
            TelaLoja(navController)
        }

        composable("detalhes/{nome}/{preco}") { backStackEntry ->
            val nome = backStackEntry.arguments?.getString("nome") ?: ""
            val preco = backStackEntry.arguments?.getString("preco") ?: ""

            TelaDetalhes(nome, preco, navController)
        }
    }
}

